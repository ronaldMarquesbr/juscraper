    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\n\nlet leads = [];\n\nfor (const item of inputItems) {\n  if (Array.isArray(item.json)) {\n    leads.push(...item.json);\n  } else if (Array.isArray(item.json.data)) {\n    leads.push(...item.json.data);\n  } else if (item.json && item.json.id) {\n    leads.push(item.json);\n  }\n}\n\nreturn leads.map((lead) => {\n  const nome = lead.name || 'NÃ£o informado';\n  const usuario = lead.username\n    ? `@${String(lead.username).replace(/^@/, '')}`\n    : 'NÃ£o informado';\n\n  const categoria = lead.category || 'NÃ£o classificada';\n  const descricao = lead.problem_description || 'Sem descriÃ§Ã£o';\n  const criadoEm = lead.created_at || 'Sem data';\n\n  const mensagem = [\n    'âš–ï¸ Novo possÃ­vel lead jurÃ­dico',\n    '',\n    `ID: ${lead.id}`,\n    `Nome: ${nome}`,\n    `Instagram: ${usuario}`,\n    `Categoria: ${categoria}`,\n    `Status: ${lead.status || 'NEW'}`,\n    `Criado em: ${criadoEm}`,\n    '',\n    'DescriÃ§Ã£o:',\n    descricao,\n    '',\n    'AÃ§Ã£o sugerida: revisar no Juscraper antes de qualquer contato externo.'\n  ].join('\\n');\n\n  return {\n    json: {\n      lead_id: lead.id,\n      mensagem,\n      lead\n    }\n  };\n});"
      },
